pipeline {
    agent any
    
    stages {
        stage('Build') {
            steps {
                echo 'Building Docker image...'
                sh 'docker build -t restaurant-menu:${BUILD_NUMBER} .'
            }
        }
        
        stage('Test') {
            steps {
                echo 'Running tests...'
                sh 'docker run --rm restaurant-menu:${BUILD_NUMBER} nginx -t'
            }
        }
        
        stage('Deploy') {
            steps {
                echo 'Deploying to Kubernetes...'
                sh 'kubectl apply -f k8s-deployment.yaml'
            }
        }
    }
}